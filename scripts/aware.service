[Unit]
Description=AWARE - Autonomous Witness And Response Engine
After=network.target bluetooth.target bluealsa.service llama-server.service aware-bt-connect.service
Wants=bluetooth.service bluealsa.service llama-server.service aware-bt-connect.service

[Service]
Type=simple
User=arduino
WorkingDirectory=/home/arduino/aware
ExecStart=/home/arduino/aware/.venv/bin/python -m aware.app.main
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
