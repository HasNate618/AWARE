AWARE_CAMERA_DEVICE=/dev/video0
AWARE_MCU_SERIAL_PORT=/dev/ttyACM0
AWARE_DB_PATH=aware.db
AWARE_TELEGRAM_TOKEN=
AWARE_TELEGRAM_CHAT_ID=
AWARE_LLM_MODEL_PATH=models/minicpm5-1b-q8.gguf
AWARE_LLM_SERVER_URL=http://127.0.0.1:8080
AWARE_LLM_TIMEOUT=180
AWARE_SENSOR_READ_INTERVAL=2.0
AWARE_SENSOR_LOG_INTERVAL=30.0
AWARE_MEMORY_SUMMARY_INTERVAL=300
AWARE_MEMORY_SUMMARY_ENABLED=true
AWARE_MEMORY_CONTEXT_MAX_CHARS=6000
AWARE_MEMORY_DEFAULT_WINDOW=3600
AWARE_LOG_LEVEL=INFO
# Enable hot reload (dev only, wastes ~64% CPU in production)
# AWARE_UVICORN_RELOAD=true
